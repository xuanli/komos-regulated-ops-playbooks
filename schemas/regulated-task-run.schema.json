{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xuanli/komos-regulated-ops-playbooks/schemas/regulated-task-run.schema.json",
  "title": "Komos Regulated Task Run",
  "description": "Portable request and response contract for Komos browser automation task runs in regulated operations queues.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/taskRunRequest"
    },
    {
      "$ref": "#/$defs/taskRunResult"
    }
  ],
  "$defs": {
    "taskRunRequest": {
      "title": "Task Run Request",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "workflow_type",
        "portal",
        "return_fields"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable identifier from the source queue or case system."
        },
        "workflow_type": {
          "type": "string",
          "minLength": 1,
          "examples": [
            "county_court_search",
            "fcra_adverse_action_notice",
            "insurance_eligibility_check",
            "statement_reconciliation"
          ]
        },
        "portal": {
          "type": "string",
          "minLength": 1,
          "description": "Human readable name or key for the target portal."
        },
        "subject": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "external_id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "first_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "date_of_birth": {
              "type": "string",
              "format": "date"
            },
            "member_id": {
              "type": "string"
            },
            "account_reference": {
              "type": "string"
            }
          }
        },
        "inputs": {
          "type": "object",
          "description": "Use case specific input fields needed to operate the portal.",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null"
            ]
          }
        },
        "return_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source_system": {
              "type": "string"
            },
            "requested_by": {
              "type": "string"
            },
            "requested_at": {
              "type": "string",
              "format": "date-time"
            },
            "policy_reference": {
              "type": "string"
            }
          }
        }
      }
    },
    "taskRunResult": {
      "title": "Task Run Result",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "status",
        "outputs"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "needs_review",
            "blocked",
            "failed"
          ]
        },
        "outputs": {
          "type": "object",
          "description": "Structured outputs returned by the Komos task run.",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null",
              "array",
              "object"
            ]
          }
        },
        "evidence": {
          "type": "array",
          "description": "Links to screenshots, PDFs, downloaded records, or run artifacts.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "url"
            ],
            "properties": {
              "type": {
                "type": "string",
                "examples": [
                  "screenshot",
                  "pdf",
                  "run_log",
                  "download"
                ]
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "captured_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        "exception_reason": {
          "type": [
            "string",
            "null"
          ],
          "examples": [
            "mfa_required",
            "portal_outage",
            "record_mismatch",
            "policy_review_required"
          ]
        },
        "next_action": {
          "type": [
            "string",
            "null"
          ],
          "examples": [
            "close_case",
            "manual_review",
            "retry",
            "request_information"
          ]
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  }
}
